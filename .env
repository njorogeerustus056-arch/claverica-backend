# ------------------------------
# Django Core (Production Settings)
# ------------------------------
DJANGO_SECRET_KEY=your_super_long_random_secret_key_here  # Generate new one (see below)
DEBUG=False  # False for production (Render sets to True only if you override)

# ------------------------------
# Database (Render PostgreSQL - NO MANUAL CREDS NEEDED)
# ------------------------------
# Render auto-injects DATABASE_URL when you link PostgreSQL add-on
# Do NOT set DB_NAME, DB_USER, etc. — use dj-database-url to parse DATABASE_URL

# ------------------------------
# Hosts & CORS (Adjust for your domains)
# ------------------------------
ALLOWED_HOSTS=claverica-backend.onrender.com,.onrender.com,localhost,127.0.0.1

CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com,http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=True

CSRF_TRUSTED_ORIGINS=https://claverica-backend.onrender.com,https://your-frontend.onrender.com,http://localhost:3000,http://localhost:5173

# ------------------------------
# Storage for Receipts/Media (Local on Render - Simple & Free)
# ------------------------------
# For production on Render, local disk works (files persist across deploys)
# If you need cloud storage later, switch to AWS S3 or similar (not Supabase)
MEDIA_URL=/media/
MEDIA_ROOT=media/

# ------------------------------
# Optional: Email, Logging, etc.
# ------------------------------
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend  # For testing
