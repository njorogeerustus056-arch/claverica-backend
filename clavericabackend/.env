# ------------------------------
# Django Core (Local Development)
# ------------------------------
DJANGO_SECRET_KEY=django-insecure-local-secret-key-please-change
DEBUG=True  # True for local development

# ------------------------------
# Database (SQLite for local dev)
# ------------------------------
DATABASE_URL=sqlite:///db.sqlite3

# ------------------------------
# Hosts & CORS
# ------------------------------
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173

# ------------------------------
# Storage for Receipts/Media
# ------------------------------
MEDIA_URL=/media/
MEDIA_ROOT=media/

# ------------------------------
# Pusher (Optional - placeholders)
# ------------------------------
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=your_pusher_cluster

# ------------------------------
# Optional: Email for local testing
# ------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
